{
    "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
    "name": "@nikbrunner/brick",
    "version": "0.1.0",
    "license": "MIT",
    "exports": "./src/main.ts",
    "tasks": {
        "install": "deno install --global -f --allow-run --allow-read --allow-env --allow-net --allow-write --name brick --config deno.json src/main.ts",
        "compile": "deno compile --allow-run --allow-read --allow-env --allow-net --allow-write --output brick src/main.ts",
        "schema": "deno run --allow-read --allow-env --allow-write scripts/generate-schema.ts",
        "test": "deno test --allow-read --allow-env",
        "check": "deno check .",
        "lint": "deno lint",
        "fmt": "deno fmt"
    },
    "imports": {
        "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
        "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
        "@std/yaml": "jsr:@std/yaml@^1.0.12",
        "@std/fmt/colors": "jsr:@std/fmt@1.0.9/colors",
        "@tanstack/ai": "npm:@tanstack/ai@^0.6.3",
        "@tanstack/ai-anthropic": "npm:@tanstack/ai-anthropic@^0.6.0",
        "zod": "npm:zod@^4.3.6"
    },
    "fmt": {
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false
    },
    "lint": {
        "rules": {
            "exclude": ["no-slow-types"]
        }
    }
}

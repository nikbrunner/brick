{
    "allowedTools": [
        "Bash(deno check:*)",
        "Bash(deno eval:*)",
        "Bash(deno fmt:*)",
        "Bash(deno lint:*)",
        "Bash(deno task:*)",
        "Bash(git *)",
        "Bash(npx @anthropic-ai/claude-code-mcp@latest *)",
        "Bash(tanstack *)",
        "Bash(tanstack doc:*)",
        "Bash(tanstack search-docs:*)",
        "mcp__Ref__ref_read_url",
        "mcp__Ref__ref_search_documentation"
    ],
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "deno fmt 2>/dev/null"
                    },
                    {
                        "type": "command",
                        "command": "deno lint 2>/dev/null"
                    },
                    {
                        "type": "command",
                        "command": "deno check . 2>/dev/null"
                    },
                    {
                        "type": "command",
                        "command": "deno task test 2>/dev/null"
                    }
                ]
            }
        ]
    }
}
